{
  "name": "rap-atlas",
  "version": "0.3.0",
  "description": "Интерактивная карта жанров, сцен и продюсерских направлений интернет-рэпа.",
  "private": true,
  "author": "Voodkid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Voodkid/rap-atlas.git"
  },
  "homepage": "https://github.com/Voodkid/rap-atlas",
  "bugs": {
    "url": "https://github.com/Voodkid/rap-atlas/issues"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "test": "vinext build && node --test tests/content-integrity.test.mjs tests/rendered-html.test.mjs",
    "typecheck": "tsc --noEmit",
    "validate:content": "node --test tests/content-integrity.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.25.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "esbuild": "0.28.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
